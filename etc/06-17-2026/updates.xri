   <platform os="all" arch="noarch" version="1.8.9-1:1.9.3">
      <package fileName="2026-05-28-pi2llm.tar.gz" sha1="c3b4fede4758006895ca06a521fd520cfc2cc74f" type="script" releaseDate="20260528">
         <title>PI2LLM, LLMAssistant update 2026 May 28</title>
         <description>
            <p>This update installs pi2llm via the approved Pixinsight update process, released May 28, 2026. This release fixes some bugs and adds enhancements and corrections for better Anthropic API support.</p>
            <p>For more information on pi2llm, please refer to:
	      <ul><li>https://stirlingastrophoto.com/posts/llm-assistant-for-pixinsight-v2/</li><li>https://github.com/scottstirling/pi2llm</li></ul>
            </p>
            <p>Copyright (c) 2026 Scott Stirling. All Rights Reserved.</p>
         </description>
      </package>
   </platform>
   <!-- ===================================================================== -->
